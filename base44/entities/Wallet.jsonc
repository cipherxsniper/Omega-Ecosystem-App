{"name":"Wallet","type":"object","properties":{"address":{"type":"string","description":"Wallet address"},"chain":{"type":"string","enum":["ethereum","polygon","solana","bitcoin","base"],"default":"ethereum"},"label":{"type":"string"},"balance_eth":{"type":"number","default":0},"balance_usd":{"type":"number","default":0},"omg_balance":{"type":"number","default":0},"is_primary":{"type":"boolean","default":false}},"required":["address","chain"]}