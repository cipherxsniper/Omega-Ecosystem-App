{"name":"ProvenanceRecord","type":"object","properties":{"asset_type":{"type":"string","enum":["nft","music","deed","game_item","document","artwork"],"default":"nft"},"asset_id":{"type":"string"},"asset_name":{"type":"string"},"sha256_hash":{"type":"string"},"metadata_signature":{"type":"string"},"signer_address":{"type":"string"},"chain":{"type":"string","default":"ethereum"},"certificate_data":{"type":"string","description":"JSON string of COA data"},"status":{"type":"string","enum":["pending","signed","verified","revoked"],"default":"pending"},"parent_record_id":{"type":"string"},"transfer_history":{"type":"string","default":"[]"}},"required":["asset_name","asset_type"]}