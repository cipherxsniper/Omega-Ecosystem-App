{"name":"AgentMemory","type":"object","properties":{"agent_name":{"type":"string"},"agent_type":{"type":"string","enum":["trading","provenance","oracle","rpg","general"],"default":"general"},"status":{"type":"string","enum":["idle","active","paused","error"],"default":"idle"},"last_action":{"type":"string"},"memory_log":{"type":"string","default":"[]"},"config":{"type":"string","default":"{}"},"performance_score":{"type":"number","default":0}},"required":["agent_name","agent_type"]}