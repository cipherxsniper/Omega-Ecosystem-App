{"name":"GameState","type":"object","properties":{"player_name":{"type":"string"},"xp":{"type":"number","default":0},"level":{"type":"number","default":1},"health":{"type":"number","default":100},"max_health":{"type":"number","default":100},"lantern_fuel":{"type":"number","default":100},"lantern_radius":{"type":"number","default":5},"current_world":{"type":"string","default":"void_nexus"},"current_x":{"type":"number","default":0},"current_y":{"type":"number","default":0},"omg_earned":{"type":"number","default":0},"nfts_discovered":{"type":"number","default":0},"bosses_defeated":{"type":"string","default":"[]"},"portals_unlocked":{"type":"string","default":"[]"},"inventory":{"type":"string","default":"[]"},"oracle_score":{"type":"number","default":50},"oracle_floor":{"type":"number","default":50},"achievements":{"type":"string","default":"[]"}},"required":["player_name"]}